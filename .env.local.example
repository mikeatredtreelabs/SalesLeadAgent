# Database — use Neon (neon.tech) for free Postgres on Vercel
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# Auth — generate with: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
NEXTAUTH_SECRET="your-secret-here"
NEXTAUTH_URL="http://localhost:3000"

# AI
ANTHROPIC_API_KEY="sk-ant-..."

# Lead discovery (optional) — free tier at apollo.io
APOLLO_API_KEY=""

# Gmail send integration (optional) — from console.cloud.google.com
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# White-label tenant (redtreeai | default)
NEXT_PUBLIC_TENANT="redtreeai"
